---
import "../styles/global.css";
import { siteText } from "../config/site";
import { defaultLocale, getLocaleFromUrl, ui } from "../i18n/ui";
import PreferencesControl from "../widgets/preferences/PreferencesControl.astro";

interface Props {
  title: string;
  description?: string;
  titleI18nKey?: string;
  titlePrefix?: string;
  titleSuffixI18nKey?: string;
  descriptionI18nKey?: string;
}

const { title, description, titleI18nKey, titlePrefix, titleSuffixI18nKey, descriptionI18nKey } = Astro.props;
const locale = Astro.url ? getLocaleFromUrl(Astro.url) : defaultLocale;
const copy = siteText[locale];
const metaDescription = description ?? copy.metaDescription;
const baseUrl = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const i18nMessages = { ui, site: siteText };
const pageI18n = {
  titleKey: titleI18nKey,
  titlePrefix,
  titleSuffixKey: titleSuffixI18nKey,
  descriptionKey: descriptionI18nKey
};
---

<!doctype html>
<html lang={locale} data-theme="light" data-accent="white" data-default-locale={defaultLocale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={metaDescription} />
    <link rel="icon" type="image/jpeg" href={`${baseUrl}favicon.jpg`} />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <div class="page-shell">
      <header class="site-header">
        <a href={`${baseUrl}?lang=${locale}`} class="brand" data-lang-link data-i18n="brand">{copy.brand}</a>
        <nav class="top-nav">
          <a href={`${baseUrl}?lang=${locale}#topics`} data-lang-link data-i18n="topics">{ui[locale].topics}</a>
          <a href={`${baseUrl}drafts/?lang=${locale}`} data-lang-link data-i18n="drafts">{ui[locale].drafts}</a>
          <a href={`${baseUrl}changelog/?lang=${locale}`} data-lang-link data-i18n="changelog">{ui[locale].changelog}</a>
        </nav>
        <PreferencesControl locale={locale} />
      </header>
      <main class="content-frame">
        <slot />
      </main>
    </div>
    <script is:inline define:vars={{ i18nMessages, defaultLocale, pageI18n }}>
      const uiDict = i18nMessages.ui;
      const siteDict = i18nMessages.site;
      const languageStorageKey = "notegen-language";
      const isSupportedLocale = (value) => value === "en" || value === "ru";
      const currentUrl = new URL(window.location.href);
      const queryLocale = currentUrl.searchParams.get("lang");
      const savedLocale = localStorage.getItem(languageStorageKey);
      const locale = isSupportedLocale(queryLocale)
        ? queryLocale
        : (isSupportedLocale(savedLocale) ? savedLocale : defaultLocale);

      const resolveMessage = (key) => {
        if (!key) return undefined;
        const parts = key.split(".");
        const firstPart = parts[0];
        const sources = firstPart === "ui"
          ? [uiDict]
          : firstPart === "site"
            ? [siteDict]
            : [uiDict, siteDict];
        const keyParts = firstPart === "ui" || firstPart === "site" ? parts.slice(1) : parts;

        for (const source of sources) {
          let value = source?.[locale];
          for (const part of keyParts) {
            value = value?.[part];
          }
          if (value !== undefined) {
            return value;
          }
        }

        return undefined;
      };

      if (currentUrl.searchParams.get("lang") !== locale) {
        currentUrl.searchParams.set("lang", locale);
        history.replaceState(null, "", currentUrl.toString());
      }

      document.documentElement.lang = locale;
      localStorage.setItem(languageStorageKey, locale);

      const titleParts = [
        pageI18n.titlePrefix,
        resolveMessage(pageI18n.titleKey),
        resolveMessage(pageI18n.titleSuffixKey)
      ].filter((part) => typeof part === "string" && part.length > 0);
      if (titleParts.length > 0) {
        document.title = titleParts.join(" | ");
      }

      const metaDescription = resolveMessage(pageI18n.descriptionKey);
      if (typeof metaDescription === "string") {
        document.querySelector('meta[name="description"]')?.setAttribute("content", metaDescription);
      }

      document.querySelectorAll("[data-i18n]").forEach((element) => {
        const key = element.getAttribute("data-i18n");
        const value = resolveMessage(key);
        if (typeof value === "string" || typeof value === "number") {
          element.textContent = value;
        }
      });

      document.querySelectorAll("[data-i18n-plural]").forEach((element) => {
        const key = element.getAttribute("data-i18n-plural");
        const count = Number(element.getAttribute("data-i18n-count"));
        const forms = resolveMessage(key);
        if (!forms || Number.isNaN(count)) return;
        const category = new Intl.PluralRules(locale).select(count);
        const label = forms[category] ?? forms.other;
        if (label) {
          element.textContent = `${count} ${label}`;
        }
      });

      document.querySelectorAll("[data-i18n-datetime]").forEach((element) => {
        const value = element.getAttribute("datetime") || element.getAttribute("data-i18n-datetime");
        if (!value) return;
        const date = new Date(value);
        if (Number.isNaN(date.getTime())) {
          element.textContent = value;
          return;
        }
        element.textContent = new Intl.DateTimeFormat(locale, {
          year: "numeric",
          month: "short",
          day: "numeric",
          hour: "2-digit",
          minute: "2-digit"
        }).format(date);
      });

      document.querySelectorAll("[data-i18n-attr]").forEach((element) => {
        const entries = element.getAttribute("data-i18n-attr")?.split(",") ?? [];
        entries.forEach((entry) => {
          const [attribute, key] = entry.split(":").map((part) => part.trim());
          const value = resolveMessage(key);
          if (attribute && (typeof value === "string" || typeof value === "number")) {
            element.setAttribute(attribute, String(value));
          }
        });
      });

      document.querySelectorAll("[data-lang-link]").forEach((element) => {
        const href = element.getAttribute("href");
        if (!href) return;
        const url = new URL(href, window.location.origin);
        url.searchParams.set("lang", locale);
        element.setAttribute("href", `${url.pathname}${url.search}${url.hash}`);
      });
    </script>
  </body>
</html>
