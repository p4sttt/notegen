---
interface Props {
  title: string;
  summary?: string;
  href: string;
  badgeLabel?: string;
}

const { title, summary, href, badgeLabel } = Astro.props;
---

<a class="entity-card" href={href} data-lang-link>
  <div class="entity-card-heading">
    <h3>{title}</h3>
    {badgeLabel ? <span class="entity-card-badge">{badgeLabel}</span> : null}
  </div>
  {summary ? <p>{summary}</p> : null}
  <div class="entity-card-footer">
    <span><slot name="meta" /></span>
  </div>
</a>
