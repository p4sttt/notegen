---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteText } from "../config/site";
import { changelog } from "../data/generated/changelog";
import { defaultLocale, getLocaleFromUrl, ui } from "../i18n/ui";

const locale = Astro.url ? getLocaleFromUrl(Astro.url) : defaultLocale;
const t = ui[locale];
const copy = siteText[locale];
const baseUrl = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;

function formatTimestamp(timestamp: string) {
  if (!timestamp) {
    return "";
  }

  const date = new Date(timestamp);
  if (Number.isNaN(date.getTime())) {
    return timestamp;
  }

  return new Intl.DateTimeFormat(locale, {
    year: "numeric",
    month: "short",
    day: "numeric",
    hour: "2-digit",
    minute: "2-digit"
  }).format(date);
}
---

<BaseLayout
  title={`${t.changelog} | ${copy.brand}`}
  description={copy.metaDescription}
  titleI18nKey="changelog"
  titleSuffixI18nKey="brand"
  descriptionI18nKey="metaDescription"
>
  <section class="home-panel changelog-shell">
    <header class="hero home-panel-section">
      <div class="hero-kicker">
        <p class="eyebrow" data-i18n="changelog">{t.changelog}</p>
        <span class="hero-tag">{changelog.length}</span>
      </div>
      <div class="hero-copy-block">
        <h1 data-i18n="changelog">{t.changelog}</h1>
      </div>
    </header>

    <hr class="section-divider" />

    <div class="changelog-list">
      {
        changelog.length === 0 ? (
          <div class="empty-state">
            <p data-i18n="changelogEmpty">{t.changelogEmpty}</p>
          </div>
        ) : (
          changelog.map((event) => {
            const title = event.href ? (
              <a href={`${baseUrl}${event.href}/?lang=${locale}`} data-lang-link>{event.title}</a>
            ) : (
              <span>{event.title}</span>
            );

            return (
              <article class={`changelog-event changelog-event-${event.action}`}>
                <div class="changelog-event-main">
                  <span class="changelog-action" data-i18n={`changelogActions.${event.action}`}>{t.changelogActions[event.action]}</span>
                  <h2>{title}</h2>
                  <p>
                    <span data-i18n={`changelogKinds.${event.kind}`}>{t.changelogKinds[event.kind]}</span>
                    {event.topic ? <span>{event.topic}</span> : null}
                    {event.oldPath ? <span>{event.oldPath} -> {event.path}</span> : <span>{event.path}</span>}
                  </p>
                </div>
                <time datetime={event.timestamp} data-i18n-datetime={event.timestamp}>{formatTimestamp(event.timestamp)}</time>
              </article>
            );
          })
        )
      }
    </div>
  </section>
</BaseLayout>
