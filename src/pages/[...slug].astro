---
import { getCollection, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteText } from "../config/site";
import { subjects, topLevelNotes } from "../data/generated/subjects";
import { getSubjectNotesCount } from "../entities/subject/model";
import { defaultLocale, formatNotesCount, getLocaleFromUrl, ui } from "../i18n/ui";
import EntityCard from "../shared/ui/EntityCard.astro";
import ContentNavigation from "../widgets/content-navigation/ContentNavigation.astro";
import SectionBlock from "../widgets/section-block/SectionBlock.astro";

export async function getStaticPaths() {
  const includeDrafts = import.meta.env.DEV;
  const subjectEntries = await getCollection("subjects", ({ data }) => includeDrafts || !data.draft);
  const notes = await getCollection("notes", ({ data }) => includeDrafts || !data.draft);

  const subjectPaths = subjectEntries
    .map((entry) => {
      const subjectSlug = entry.data.slug ?? entry.slug;
      const subject = subjects.find((item) => item.slug === subjectSlug);
      if (!subject) {
        return null;
      }

      return {
        params: { slug: subjectSlug },
        props: { kind: "subject", subject, entry }
      };
    })
    .filter(Boolean);

  const generatedNotes = [...subjects.flatMap((subject) => subject.notes), ...topLevelNotes];
  const notePaths = notes.map((note) => {
    const generatedNote = generatedNotes.find((item) => item.sourcePath === note.data.sourcePath);
    return {
      params: { slug: generatedNote?.collectionSlug ?? note.slug },
      props: { kind: "note", note }
    };
  });

  return [...subjectPaths, ...notePaths];
}

const locale = Astro.url ? getLocaleFromUrl(Astro.url) : defaultLocale;
const copy = siteText[locale];
const t = ui[locale];
const baseUrl = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const props = Astro.props as any;
const includeDrafts = import.meta.env.DEV;
const visibleSubjects = includeDrafts ? subjects : subjects.filter((subject) => !subject.draft);
const subjectRender = props.kind === "subject" ? await render(props.entry) : null;
const noteRender = props.kind === "note" ? await render(props.note) : null;
const SubjectContent = subjectRender?.Content;
const NoteContent = noteRender?.Content;
const headings = noteRender?.headings ?? [];
---

{
  props.kind === "subject" ? (
    (() => {
      const { subject } = props;
      const childSubjects = visibleSubjects.filter((item) => item.parentSlug === subject.slug);
      const visibleNotes = includeDrafts ? subject.notes : subject.notes.filter((note: any) => !note.draft);
      const totalNotesCount = getSubjectNotesCount(subject, visibleSubjects, includeDrafts);
      return (
        <BaseLayout title={`${subject.title} | ${copy.brand}`} description={subject.summary ?? copy.metaDescription}>
          <div class="home-panel">
            <section class="hero home-panel-section">
              <div class="hero-kicker">
                <p class="eyebrow" data-i18n="subjects">{t.subjects}</p>
                <span class="hero-tag">
                  {formatNotesCount(locale, totalNotesCount)}
                </span>
              </div>
              <div class="hero-copy-block">
                <h1>{subject.title}</h1>
              </div>
              <div class="prose subject-prose">
                {SubjectContent ? <SubjectContent /> : null}
              </div>
            </section>

            <hr class="section-divider" />

            {childSubjects.length > 0 ? (
              <>
                <SectionBlock title={t.subjects} count={childSubjects.length} i18nKey="subjects">
                  <div class="entity-grid">
                    {childSubjects.map((child) => (
                      <EntityCard title={child.title} summary={child.description || child.summary} href={`${baseUrl}${child.slug}/?lang=${locale}`}>
                        <Fragment slot="meta">{formatNotesCount(locale, getSubjectNotesCount(child, visibleSubjects, includeDrafts))}</Fragment>
                      </EntityCard>
                    ))}
                  </div>
                </SectionBlock>
                <hr class="section-divider" />
              </>
            ) : null}

            <SectionBlock title={t.notes} count={visibleNotes.length} i18nKey="notes">
              {visibleNotes.length === 0 ? (
                <div class="empty-state">
                  <p>{t.empty}</p>
                </div>
              ) : (
                <div class="entity-grid">
                  {visibleNotes.map((note: any) => (
                    <EntityCard title={note.title} summary={note.summary} href={`${baseUrl}${note.collectionSlug}/?lang=${locale}`}>
                      <Fragment slot="meta">{note.updatedAt ?? note.sourcePath}</Fragment>
                    </EntityCard>
                  ))}
                </div>
              )}
            </SectionBlock>
          </div>
        </BaseLayout>
      );
    })()
  ) : (
    (() => {
      const { note } = props;
      return (
        <BaseLayout title={`${note.data.title} | ${copy.brand}`} description={note.data.title}>
          <article class="note-shell home-panel">
            <header class="note-header note-header-compact home-panel-section">
              <div class="hero-kicker">
                <p class="eyebrow">{note.data.subject ?? copy.brand}</p>
                <span class="hero-tag">{note.data.date ? note.data.date.toISOString().slice(0, 10) : t.sourceData}</span>
              </div>
              <div class="hero-copy-block">
                <h1 class="note-title">{note.data.title}</h1>
              </div>
            </header>

            <hr class="section-divider" />

            <div class="note-layout note-panel-body">
              <ContentNavigation headings={headings} title={t.contents} />

              <div class="note-card prose">
                {note.data.subjectSlug ? (
                  <p class="note-backline">
                    <a href={`${baseUrl}${note.data.subjectSlug}/?lang=${locale}`} data-lang-link>{note.data.subject}</a>
                  </p>
                ) : null}
                {NoteContent ? <NoteContent /> : null}
              </div>
            </div>
          </article>
        </BaseLayout>
      );
    })()
  )
}
