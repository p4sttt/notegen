---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteText } from "../config/site";
import { topics, topLevelDatabases, topLevelNotes } from "../data/generated/topics";
import { getTopicNotesCount, isInProgressNote, isPublishedNote } from "../entities/topic/model";
import { defaultLocale, formatDatabaseRowsCount, formatNotesCount, getLocaleFromUrl, ui } from "../i18n/ui";
import EntityCard from "../shared/ui/EntityCard.astro";
import Hero from "../widgets/hero/Hero.astro";
import SectionBlock from "../widgets/section-block/SectionBlock.astro";

const locale = Astro.url ? getLocaleFromUrl(Astro.url) : defaultLocale;
const t = ui[locale];
const copy = siteText[locale];
const baseUrl = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const includeDrafts = import.meta.env.DEV;
const visibleTopics = includeDrafts ? topics : topics.filter((topic) => !topic.draft);
const rootTopics = visibleTopics.filter((topic) => !topic.parentSlug);
const visibleTopLevelNotes = topLevelNotes.filter(isPublishedNote);
const visibleTopLevelDatabases = topLevelDatabases;
---

<BaseLayout title={copy.brand} description={copy.metaDescription} titleI18nKey="brand" descriptionI18nKey="metaDescription">
  <div class="home-panel">
    <Hero
      title={copy.heroTitle}
      eyebrow={copy.heroEyebrow}
      tag={copy.heroTag}
      titleI18nKey="heroTitle"
      eyebrowI18nKey="heroEyebrow"
      tagI18nKey="heroTag"
    >
      <p class="hero-copy" data-i18n="heroBody">{copy.heroBody}</p>
    </Hero>

    <hr class="section-divider" />

    <SectionBlock id="topics" title={t.topics} count={rootTopics.length} i18nKey="topics">
      {
        rootTopics.length === 0 ? (
          <div class="empty-state">
            <p data-i18n="empty">{t.empty}</p>
          </div>
        ) : (
          <div class="entity-grid">
            {rootTopics.map((topic) => {
              const notesCount = getTopicNotesCount(topic, visibleTopics, includeDrafts);
              return (
              <EntityCard title={topic.title} summary={topic.description || topic.summary} href={`${baseUrl}${topic.slug}/?lang=${locale}`}>
                <Fragment slot="meta">
                  <span data-i18n-plural="notesCount" data-i18n-count={notesCount}>
                    {formatNotesCount(locale, notesCount)}
                  </span>
                </Fragment>
              </EntityCard>
              );
            })}
          </div>
        )
      }
    </SectionBlock>

    <hr class="section-divider" />

    <SectionBlock id="notes" title={t.notes} count={visibleTopLevelNotes.length} i18nKey="notes">
      {
        visibleTopLevelNotes.length === 0 ? (
          <div class="empty-state">
            <p data-i18n="empty">{t.empty}</p>
          </div>
        ) : (
          <div class="entity-grid">
            {visibleTopLevelNotes.map((note) => (
              <EntityCard
                title={note.title}
                summary={note.summary}
                href={`${baseUrl}${note.collectionSlug}/?lang=${locale}`}
                badgeLabel={isInProgressNote(note) ? t.inProgress : undefined}
                badgeI18nKey={isInProgressNote(note) ? "inProgress" : undefined}
              >
                <Fragment slot="meta">{note.updatedAt ?? note.sourcePath}</Fragment>
              </EntityCard>
            ))}
          </div>
        )
      }
    </SectionBlock>

    <hr class="section-divider" />

    <SectionBlock id="databases" title={t.databases} count={visibleTopLevelDatabases.length} i18nKey="databases">
      {
        visibleTopLevelDatabases.length === 0 ? (
          <div class="empty-state">
            <p data-i18n="empty">{t.empty}</p>
          </div>
        ) : (
          <div class="entity-grid">
            {visibleTopLevelDatabases.map((database) => (
              <EntityCard
                title={database.title}
                summary={database.summary}
                href={`${baseUrl}${database.collectionSlug}/?lang=${locale}`}
              >
                <Fragment slot="meta">{formatDatabaseRowsCount(locale, database.rows.length)}</Fragment>
              </EntityCard>
            ))}
          </div>
        )
      }
    </SectionBlock>
  </div>
</BaseLayout>
