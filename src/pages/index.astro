---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteText } from "../config/site";
import { subjects, topLevelNotes } from "../data/generated/subjects";
import { defaultLocale, getLocaleFromUrl, ui } from "../i18n/ui";
import EntityCard from "../shared/ui/EntityCard.astro";
import Hero from "../widgets/hero/Hero.astro";
import SectionBlock from "../widgets/section-block/SectionBlock.astro";

const locale = Astro.url ? getLocaleFromUrl(Astro.url) : defaultLocale;
const t = ui[locale];
const copy = siteText[locale];
const baseUrl = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const visibleSubjects = import.meta.env.DEV ? subjects : subjects.filter((subject) => !subject.draft);
const rootSubjects = visibleSubjects.filter((subject) => !subject.parentSlug);
const visibleTopLevelNotes = import.meta.env.DEV ? topLevelNotes : topLevelNotes.filter((note) => !note.draft);
---

<BaseLayout title={copy.brand} description={copy.metaDescription}>
  <div class="home-panel">
    <Hero
      title={copy.heroTitle}
      eyebrow={copy.heroEyebrow}
      tag={copy.heroTag}
      titleI18nKey="heroTitle"
      eyebrowI18nKey="heroEyebrow"
      tagI18nKey="heroTag"
    >
      <p class="hero-copy" data-i18n="heroBody">{copy.heroBody}</p>
    </Hero>

    <hr class="section-divider" />

    <SectionBlock id="subjects" title={t.subjects} count={rootSubjects.length} i18nKey="subjects">
      {
        rootSubjects.length === 0 ? (
          <div class="empty-state">
            <p>{t.empty}</p>
          </div>
        ) : (
          <div class="entity-grid">
            {rootSubjects.map((subject) => (
              <EntityCard title={subject.title} summary={subject.description || subject.summary} href={`${baseUrl}${subject.slug}/?lang=${locale}`}>
                <Fragment slot="meta">
                  {subject.notes.length} <span data-i18n="notesCount">{t.notesCount}</span>
                </Fragment>
              </EntityCard>
            ))}
          </div>
        )
      }
    </SectionBlock>

    <hr class="section-divider" />

    <SectionBlock id="notes" title={t.notes} count={visibleTopLevelNotes.length} i18nKey="notes">
      {
        visibleTopLevelNotes.length === 0 ? (
          <div class="empty-state">
            <p>{t.empty}</p>
          </div>
        ) : (
          <div class="entity-grid">
            {visibleTopLevelNotes.map((note) => (
              <EntityCard title={note.title} summary={note.summary} href={`${baseUrl}${note.collectionSlug}/?lang=${locale}`}>
                <Fragment slot="meta">{note.updatedAt ?? note.sourcePath}</Fragment>
              </EntityCard>
            ))}
          </div>
        )
      }
    </SectionBlock>
  </div>
</BaseLayout>
