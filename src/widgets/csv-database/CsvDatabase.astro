---
import type { Database } from "../../data/generated/topics";
import { formatDatabaseRowsCount, ui, type Locale } from "../../i18n/ui";

interface Props {
  database: Database;
  locale: Locale;
}

const { database, locale } = Astro.props;
const t = ui[locale];
const payloadId = `csv-database-${database.collectionSlug.replace(/[^a-z0-9_-]+/gi, "-")}`;
const isTruthyBoolean = (value: unknown) => /^(true|yes|да|1)$/i.test(String(value ?? "").trim());
const payload = JSON.stringify({
  columns: database.columns,
  rows: database.rows,
  locale,
  labels: {
    visibleRows: t.visibleRows,
    empty: t.empty,
    reset: t.reset,
    rowForms: t.databaseRowsCount
  }
}).replace(/</g, "\\u003c");
---

<section class="database-view" data-database-view data-payload-id={payloadId}>
  <div class="database-toolbar">
    <label class="database-search">
      <span>{t.search}</span>
      <input type="search" data-database-search placeholder={`${t.search}...`} autocomplete="off" />
    </label>

    <button class="database-reset" type="button" data-database-reset>{t.reset}</button>
  </div>

  <div class="database-status-line">
    <span data-database-visible>
      {t.visibleRows} {formatDatabaseRowsCount(locale, database.rows.length)}
    </span>
    <span>{database.columns.length} {t.columns.toLowerCase()}</span>
  </div>

  {database.columns.length > 0 ? (
    <div class="database-controls">
      <details class="database-control-panel" open>
        <summary>{t.filters}</summary>
        <div class="database-filter-grid">
          {database.columns.map((column) => (
            <label>
              <span>{column.label}</span>
              <input type="search" data-column-filter={column.key} placeholder={column.type} autocomplete="off" />
            </label>
          ))}
        </div>
      </details>

      <details class="database-control-panel">
        <summary>{t.columns}</summary>
        <div class="database-column-list">
          {database.columns.map((column) => (
            <label>
              <input type="checkbox" data-column-toggle={column.key} checked />
              <span>{column.label}</span>
            </label>
          ))}
        </div>
      </details>
    </div>
  ) : null}

  <div class="database-table-scroll" tabindex="0">
    <table class="database-table">
      <thead>
        <tr>
          {database.columns.map((column) => (
            <th data-column={column.key} aria-sort="none">
              <button type="button" data-sort-column={column.key}>
                <span>{column.label}</span>
                <span class="database-column-type">{column.type}</span>
                <span class="database-sort-mark" data-sort-mark aria-hidden="true"></span>
              </button>
            </th>
          ))}
        </tr>
      </thead>
      <tbody data-database-body>
        {database.rows.map((row) => (
          <tr>
            {database.columns.map((column) => (
              <td data-column={column.key}>
                {column.type === "boolean" ? (
                  <button
                    class="database-boolean-cell"
                    type="button"
                    aria-pressed={isTruthyBoolean(row[column.key])}
                    aria-label={isTruthyBoolean(row[column.key]) ? "true" : "false"}
                    tabindex="-1"
                  >
                    <span aria-hidden="true">{isTruthyBoolean(row[column.key]) ? "✓" : ""}</span>
                  </button>
                ) : (
                  row[column.key]
                )}
              </td>
            ))}
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <p class="database-empty" data-database-empty hidden>{t.empty}</p>
</section>

<script is:inline id={payloadId} type="application/json" set:html={payload}></script>

<script is:inline>
  function initDatabaseView(view) {
    if (view.dataset.databaseReady === "true") {
      return;
    }
    view.dataset.databaseReady = "true";

    const payload = JSON.parse(document.getElementById(view.dataset.payloadId).textContent);
    const columns = payload.columns;
    const rows = payload.rows;
    const searchInput = view.querySelector("[data-database-search]");
    const resetButton = view.querySelector("[data-database-reset]");
    const body = view.querySelector("[data-database-body]");
    const visibleCounter = view.querySelector("[data-database-visible]");
    const emptyState = view.querySelector("[data-database-empty]");
    const filterInputs = Array.from(view.querySelectorAll("[data-column-filter]"));
    const columnToggles = Array.from(view.querySelectorAll("[data-column-toggle]"));
    const sortButtons = Array.from(view.querySelectorAll("[data-sort-column]"));
    const sortState = { key: "", direction: "none" };
    const visibleColumns = new Set(columns.map((column) => column.key));

    function rowLabel(count) {
      const category = new Intl.PluralRules(payload.locale).select(count);
      const label = payload.labels.rowForms[category] || payload.labels.rowForms.other;
      return `${count} ${label}`;
    }

    function normalized(value) {
      return String(value ?? "").toLowerCase();
    }

    function sortableValue(row, column) {
      const value = String(row[column.key] ?? "").trim();
      if (column.type === "number") {
        return Number(value.replace("%", "").replace(",", "."));
      }
      if (column.type === "date") {
        return Date.parse(value);
      }
      if (column.type === "boolean") {
        return /^(true|yes|да|1)$/i.test(value) ? 1 : 0;
      }
      return value.toLocaleLowerCase(payload.locale);
    }

    function booleanButton(value) {
      const checked = /^(true|yes|да|1)$/i.test(String(value ?? "").trim());
      const button = document.createElement("button");
      const mark = document.createElement("span");

      button.className = "database-boolean-cell";
      button.type = "button";
      button.tabIndex = -1;
      button.setAttribute("aria-pressed", String(checked));
      button.setAttribute("aria-label", checked ? "true" : "false");
      mark.setAttribute("aria-hidden", "true");
      mark.textContent = checked ? "✓" : "";
      button.append(mark);

      return button;
    }

    function compareRows(left, right) {
      if (!sortState.key || sortState.direction === "none") {
        return 0;
      }

      const column = columns.find((item) => item.key === sortState.key);
      const leftValue = sortableValue(left, column);
      const rightValue = sortableValue(right, column);
      const emptyLeft = leftValue === "" || Number.isNaN(leftValue);
      const emptyRight = rightValue === "" || Number.isNaN(rightValue);

      if (emptyLeft && emptyRight) return 0;
      if (emptyLeft) return 1;
      if (emptyRight) return -1;
      if (leftValue > rightValue) return sortState.direction === "asc" ? 1 : -1;
      if (leftValue < rightValue) return sortState.direction === "asc" ? -1 : 1;
      return 0;
    }

    function activeFilters() {
      return filterInputs
        .map((input) => ({ key: input.dataset.columnFilter, query: normalized(input.value).trim() }))
        .filter((filter) => filter.query);
    }

    function filteredRows() {
      const query = normalized(searchInput.value).trim();
      const filters = activeFilters();

      return rows
        .filter((row) => {
          const matchesSearch =
            !query ||
            columns.some((column) => normalized(row[column.key]).includes(query));
          const matchesFilters = filters.every((filter) => normalized(row[filter.key]).includes(filter.query));
          return matchesSearch && matchesFilters;
        })
        .map((row, index) => ({ row, index }))
        .sort((left, right) => compareRows(left.row, right.row) || left.index - right.index)
        .map((entry) => entry.row);
    }

    function renderTable(nextRows) {
      const fragment = document.createDocumentFragment();

      for (const row of nextRows) {
        const tr = document.createElement("tr");
        for (const column of columns) {
          const td = document.createElement("td");
          td.dataset.column = column.key;
          if (column.type === "boolean") {
            td.append(booleanButton(row[column.key]));
          } else {
            td.textContent = row[column.key] ?? "";
          }
          td.hidden = !visibleColumns.has(column.key);
          tr.append(td);
        }
        fragment.append(tr);
      }

      body.replaceChildren(fragment);
      emptyState.hidden = nextRows.length > 0;
      visibleCounter.textContent = `${payload.labels.visibleRows} ${rowLabel(nextRows.length)} / ${rowLabel(rows.length)}`;
    }

    function updateColumnVisibility() {
      for (const cell of view.querySelectorAll("[data-column]")) {
        cell.hidden = !visibleColumns.has(cell.dataset.column);
      }
    }

    function updateSortButtons() {
      for (const button of sortButtons) {
        const key = button.dataset.sortColumn;
        const active = key === sortState.key && sortState.direction !== "none";
        const mark = button.querySelector("[data-sort-mark]");
        const th = button.closest("th");
        button.dataset.active = String(active);
        mark.textContent = active ? (sortState.direction === "asc" ? "↑" : "↓") : "";
        th.setAttribute("aria-sort", active ? (sortState.direction === "asc" ? "ascending" : "descending") : "none");
      }
    }

    function update() {
      updateSortButtons();
      renderTable(filteredRows());
      updateColumnVisibility();
    }

    searchInput.addEventListener("input", update);
    for (const input of filterInputs) {
      input.addEventListener("input", update);
    }

    for (const checkbox of columnToggles) {
      checkbox.addEventListener("change", () => {
        if (checkbox.checked) {
          visibleColumns.add(checkbox.dataset.columnToggle);
        } else {
          visibleColumns.delete(checkbox.dataset.columnToggle);
        }
        updateColumnVisibility();
      });
    }

    for (const button of sortButtons) {
      button.addEventListener("click", () => {
        const key = button.dataset.sortColumn;
        if (sortState.key !== key) {
          sortState.key = key;
          sortState.direction = "asc";
        } else if (sortState.direction === "asc") {
          sortState.direction = "desc";
        } else {
          sortState.key = "";
          sortState.direction = "none";
        }
        update();
      });
    }

    resetButton.addEventListener("click", () => {
      searchInput.value = "";
      for (const input of filterInputs) input.value = "";
      for (const checkbox of columnToggles) {
        checkbox.checked = true;
        visibleColumns.add(checkbox.dataset.columnToggle);
      }
      sortState.key = "";
      sortState.direction = "none";
      update();
    });

    update();
  }

  for (const view of document.querySelectorAll("[data-database-view]")) {
    initDatabaseView(view);
  }
</script>
