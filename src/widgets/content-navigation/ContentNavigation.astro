---
type Heading = {
  depth: number;
  slug: string;
  text: string;
};

interface Props {
  headings: Heading[];
  title: string;
}

const { headings, title } = Astro.props;
---

{
  headings.length > 0 ? (
    <aside class="toc-card">
      <p class="prefs-label" data-i18n="contents">{title}</p>
      <nav class="toc-nav">
        {headings.map((heading) => (
          <a class={`toc-link toc-link-depth-${heading.depth}`} href={`#${heading.slug}`}>
            {heading.text}
          </a>
        ))}
      </nav>
    </aside>
  ) : null
}
